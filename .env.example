# Copy to .env.local and fill in. All non-optional vars are required for
# `pnpm dev` to boot.

# --- Database ---
# PostgreSQL connection string. Prisma 7 reads this at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# --- Auth.js ---
# 32-byte random secret. Generate with: `openssl rand -base64 32`
AUTH_SECRET=""

# Optional OAuth providers. The login page hides the button when a pair is
# missing, so you can enable either or both independently.
# DISCORD_CLIENT_ID=""
# DISCORD_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# --- Redis (rate limiting) ---
# When unset the rate limiter falls back to an in-process Map — fine for
# local dev but don't deploy without Redis on multiple instances.
REDIS_URL=""

# --- Media storage ---
# Where uploaded tracks + sample files live on disk. In prod put this on a
# persistent volume outside the repo (e.g. /var/lib/beatbattle/media) and
# alias MEDIA_PUBLIC_BASE via nginx straight to it.
MEDIA_ROOT="./media"
# Public URL prefix the client uses. In dev Next serves this via a route
# handler; in prod nginx should intercept the same path.
MEDIA_PUBLIC_BASE="/media"
